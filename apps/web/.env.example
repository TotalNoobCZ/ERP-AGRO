# Zkopíruj do .env.local a doplň hodnoty ze Supabase projektu
# (Dashboard → Settings → API), případně z `supabase start` pro lokální vývoj.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key>

# Jen server-side (API routes) – NIKDY neposílat do prohlížeče.
# Používá se pro flow „Jsem tu poprvé" (založení auth účtu k profilu).
SUPABASE_SERVICE_ROLE_KEY=<service role key>
