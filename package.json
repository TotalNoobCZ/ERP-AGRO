{
  "name": "erp-agro",
  "private": true,
  "description": "ERP AGRO – jeden systém ze tří aplikací (Poptávky, Zakázky/Plánování, Konstrukce)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @erp/web",
    "build": "npm run build -w @erp/web",
    "start": "npm run start -w @erp/web",
    "lint": "npm run lint -w @erp/web",
    "typecheck": "npm run typecheck -w @erp/web",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "migrate": "node packages/db/migrate/migrate.mjs"
  },
  "engines": {
    "node": ">=20.9"
  },
  "devDependencies": {
    "supabase": "^2.109.1"
  }
}
